{
  "permissions": {
    "allow": [
      "Bash(nm *)",
      "Bash(otool *)",
      "Bash(adb *)",
      "Bash(git worktree *)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(python3 *)",
      "Bash(cmux set-status *)",
      "Bash(cmux set-progress *)",
      "Bash(cmux log *)",
      "Bash(cmux notify *)",
      "Bash(cmux identify *)",
      "Bash(cmux list-panels *)",
      "Bash(cmux list-pane-surfaces *)",
      "Bash(cmux list-workspaces *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-dangerous-git.sh"
          }
        ]
      }
    ]
  }
}
